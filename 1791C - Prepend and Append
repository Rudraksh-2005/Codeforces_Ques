#include<bits/stdc++.h>
using namespace std;

int main(){
     int t;
     cin>>t;
     
     while(t--){
          int n;
          cin>>n;
          string s;
          cin>>s;
          
          int i=0;
          int j=s.length()-1;
          int ans=0;
          
          while(i<=j){
              if((s[i]=='0' && s[j]=='1' ) || (s[j]=='0' && s[i]=='1' )){
                   i++;
                   j--;
              }else{
                   ans=j-i+1;
                   break;
              }
          }
          
          cout<<ans<<endl;
     }
     
     return 0;
}
