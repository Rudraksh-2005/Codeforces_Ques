#include<bits/stdc++.h>
using namespace std;
 
int main(){
    int t;
    cin >> t;
     
    while(t--){
        int n;
        cin >> n;
        vector<int> arr;
          
        for(int i = 0; i < n; i++){
            int a;
            cin >> a;
            arr.push_back(a);
        }
          
        int cnt = 0;
        int maxi = 0;
          
        for(int i = 0; i < n; i++){
            if(arr[i] == 0){
                cnt++;
            } else {
                cnt = 0;
            }
               
            maxi = max(maxi, cnt);
        }
          
        cout << maxi << endl;
    }
     
    return 0;
}
