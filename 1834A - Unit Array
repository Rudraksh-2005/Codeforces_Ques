#include<bits/stdc++.h>
using namespace std;
 
int main(){
     
     int t;
     cin>>t;
     while(t--){
          int n;
          cin>>n;
          vector<int>arr;
          int sum=0;
          int one=0;
          
          int cnt=0;
          
          for(int i=0;i<n;i++){
               int a;
               cin>>a;
               
               arr.push_back(a);
               sum+=a;
               if(a==-1)one++;
          }
          
          if(sum>=0 && one%2==0){
               cout<<"0"<<endl;
               continue;
          }
          else{
               while(sum<0 || one%2!=0 ){
                    sum+=2;
                    one--;
                    cnt++;
               }
          }
          
          cout<<cnt<<endl;
          
          
          
     }
     
     
     
     
     return 0;
}
