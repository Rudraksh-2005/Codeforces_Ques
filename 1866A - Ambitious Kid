#include<bits/stdc++.h>
using namespace std;

int main(){
     int n;
     cin>>n;
     
     int mini=INT_MAX;
     
     vector<int>arr(n,0);
     for(int i=0;i<n;i++){
          int a;
          cin>>a;
          if(abs(a)<mini)mini=abs(a);
          arr[i]=a;
          if(a==0){
               cout<<0<<endl;
               break;
          }
     }

     if(mini!=0)cout<<mini<<endl;
     
     return 0;
}
