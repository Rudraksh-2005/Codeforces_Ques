#include<bits/stdc++.h>
using namespace std;
 
int main(){
     int t;
     cin>>t;
     while(t--){
          vector<vector<char>>mat(10,vector<char>(10));
          for(int i=0;i<10;i++){
               string s;
               cin>>s;
               for(int j=0;j<10;j++){
                    mat[i][j]=s[j];
               }
               
          }
          
          int ans=0;
          
          for(int i=0;i<10;i++){
               for(int j=0;j<10;j++){
                    if(i==0 || i==9 || j==0|| j==9){
                         if(mat[i][j]=='X'){
                              ans+=1;
                         }
                    }
                    else if(i==1 || i==8 || j==1|| j==8){
                         if(mat[i][j]=='X'){
                              ans+=2;
                         }
                    }
                    else if(i==2 || i==7 || j==2|| j==7){
                         if(mat[i][j]=='X'){
                              ans+=3;
                         }
                    }
                    else if(i==3 || i==6|| j==3|| j==6){
                         if(mat[i][j]=='X'){
                              ans+=4;
                         }
                    }
                    else if(i==4|| i==5 || j==4|| j==5){
                         if(mat[i][j]=='X'){
                              ans+=5;
                         }
                    }
               }
          }
          
          cout<<ans<<endl;
          
     }
     
     return 0;
     
}
