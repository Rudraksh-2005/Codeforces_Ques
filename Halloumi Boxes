#include <bits/stdc++.h>
using namespace std;
 
int main() {
    int n;
    cin >> n;
 
    while(n--) {
        int m, k;
        cin >> m >> k;
 
        vector<int> arr(m);
        for(int i = 0; i < m; i++) {
            cin >> arr[i];
        }
 
        vector<int> ans = arr;
        sort(ans.begin(), ans.end());
 
        if(k == 1) {
            if(ans == arr) cout << "YES\n";
            else cout << "NO\n";
        } else {
            cout << "YES\n";
        }
    }
 
    return 0;
}
